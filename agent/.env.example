# מומלץ: לא לערוך ידנית — הרץ `npm run setup` והקובץ ייווצר אוטומטית.
#
# === הגדרות חובה ===
ATTENDANCE_INGEST_TOKEN=paste_your_token_here
SUPABASE_FUNCTIONS_URL=https://rhzmhiknbcipucfvgkok.supabase.co/functions/v1
COMPANY_ID=paste_your_company_uuid_here

# קידומת לקוד עובד — בשעון מופיע 363, במערכת EMP-363, אז שים EMP-
EMPLOYEE_CODE_PREFIX=EMP-

# גודל באצ' לשליחה ל-edge function (מקסימום 500)
BATCH_SIZE=200

# === הגנת תאריך ===
# תאריך מינימלי קשיח — שום רשומה לפני זה לא תישלח, גם אם לא הועבר --since
HARD_MIN_DATE=2026-04-01T00:00:00Z
# ברירת מחדל ל-since אם לא הועבר בשורת הפקודה
DEFAULT_SINCE=2026-04-01T00:00:00Z

# === חיבור לשעון ZKTeco U560 ===
CLOCK_HOST=10.0.0.114
CLOCK_PORT=4370
# inport — פורט UDP מקומי שמאזין לתשובות בינאריות. השאר 5200 אלא אם תפוס.
CLOCK_INPORT=5200
# timeout (ms) לכל פקודה
CLOCK_TIMEOUT=5500
# פרוטוקול תקשורת לשעון:
#   udp  — מומלץ ל-U560 (ZK הישן לרוב לא עונה ל-handshake ב-TCP גם שהפורט פתוח)
#   tcp  — מכשירים חדשים יותר
#   auto — מנסה TCP ואז UDP fallback
CLOCK_PROTOCOL=udp

# === הגדרות פולינג ===
# כל כמה שניות למשוך פאנצ'ים חדשים
POLL_INTERVAL_MS=30000
# האם למחוק מהשעון פאנצ'ים אחרי שנשלחו בהצלחה? false מומלץ עד שתאמת שהכול עובד.
CLEAR_AFTER_SEND=false

# === קובץ סטייט (איזה פאנצ'ים כבר נשלחו) ===
STATE_FILE=./state.json

# === עדכון אוטומטי ===
# הסוכן בודק כל שעה manifest.json בכתובת AGENT_MANIFEST_URL,
# ואם הגרסה שם גבוהה — מוריד, מגבה לקיים ב-.update-backup/ ועושה restart דרך ה-Service.
AUTO_UPDATE=true
AGENT_MANIFEST_URL=https://tiful360.com/agent/manifest.json
UPDATE_CHECK_INTERVAL_MS=3600000
